probability ( Nature_of_stain | Saliva, Risk ) {
  (Yes, High) 1.0, 0.0, 0.0;
  (No, High) 0.00, 0.99, 0.01;
  (Yes, Low) 1.0, 0.0, 0.0;
  (No, Low) 0.00, 0.01, 0.99;
