network unknown {
}
variable Risk {
  type discrete [ 2 ] { High, Low };
}
variable Saliva {
  type discrete [ 2 ] { Yes, No };
}
variable RSID {
  type discrete [ 3 ] { Positive, Negative, Weak positive };
}
variable Concentration {
  type discrete [ 8 ] { 0 - 0.0002, 0.0002 - 0.0005, 0.0005 - 0.001, 0.001 - 0.002, 0.002 - 0.004, 0.004 - 0.01, 0.01 - 0.02, 0.02 - inf };
}
variable Nature_of_stain {
  type discrete [ 3 ] { Saliva, Fecal matter_ vaginal secretion_ sperm_ breast milk_ urine, Other };
}
probability ( Risk ) {
  table 0.5, 0.5;
}
probability ( Saliva ) {
  table 0.5, 0.5;
}
probability ( RSID | Nature_of_stain, Concentration ) {
