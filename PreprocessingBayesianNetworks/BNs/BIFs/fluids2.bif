  (Other, 0.001 - 0.002) 0.033, 0.933, 0.034;
  (Saliva, 0.002 - 0.004) 0.80, 0.04, 0.16;
  (Fecal matter_ vaginal secretion_ sperm_ breast milk_ urine, 0.002 - 0.004) 0.033, 0.933, 0.034;
  (Other, 0.002 - 0.004) 0.033, 0.933, 0.034;
  (Saliva, 0.004 - 0.01) 0.80, 0.04, 0.16;
