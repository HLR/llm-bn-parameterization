network unknown {
}
variable Basement {
  type discrete [ 2 ] { False, True };
}
variable BlueConcrete {
  type discrete [ 2 ] { False, True };
}
variable BuildingClass {
  type discrete [ 4 ] { Single Family House, MultiFamily House, School Building, Other Building };
}
variable FloorArea {
  type discrete [ 5 ] { 0-150, 150-220, 220-360, 360-1500, >1500 };
}
probability ( Basement ) {
  table 0.34, 0.66;
}
probability ( BlueConcrete ) {
  table 0.64, 0.36;
}
probability ( BuildingClass | Basement, BlueConcrete ) {
  (False, False) 0.47, 0.05, 0.27, 0.21;
  (True, False) 0.44, 0.37, 0.08, 0.11;
  (False, True) 0.07, 0.58, 0.16, 0.19;
  (True, True) 0.14, 0.54, 0.05, 0.27;
}
probability ( FloorArea | Basement, BuildingClass ) {
  (False, Single Family House) 0.76, 0.20, 0.04, 0.00, 0.00;
  (True, Single Family House) 0.18, 0.45, 0.36, 0.01, 0.00;
  (False, MultiFamily House) 0.00, 0.00, 0.35, 0.20, 0.45;
  (True, MultiFamily House) 0.00, 0.00, 0.09, 0.50, 0.41;
  (False, School Building) 0.05, 0.02, 0.09, 0.66, 0.18;
  (True, School Building) 0.03, 0.01, 0.11, 0.29, 0.56;
  (False, Other Building) 0.02, 0.00, 0.12, 0.54, 0.32;
  (True, Other Building) 0.02, 0.00, 0.04, 0.26, 0.68;
}
