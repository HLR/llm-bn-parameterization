network unknown {
}
variable Income {
  type discrete [ 2 ] { $0-$40_000, $40_000+ };
}
variable Sex {
  type discrete [ 2 ] { male, female };
}
variable Marriage {
  type discrete [ 5 ] { married, cohabitation, divorced, widowed, single };
}
variable Age {
  type discrete [ 2 ] { 14-34, 35+ };
}
variable Education {
  type discrete [ 2 ] { no college graduate, college graduate };
}
variable Occupation {
  type discrete [ 9 ] { professional/managerial, sales, laborer, clerical/service, homemaker, student, military, retired, unemployed };
}
variable Bay {
  type discrete [ 2 ] { 1-9, 10+ };
}
variable No of people {
  type discrete [ 2 ] { 1, 2+ };
}
variable Children {
  type discrete [ 2 ] { 0, 1+ };
}
variable Rent {
  type discrete [ 3 ] { own, rent, live with parents/family };
}
variable Type {
  type discrete [ 5 ] { house, condominium, apartment, mobile Home, other };
}
variable Ethnicity {
  type discrete [ 8 ] { american indian, asian, black, east indian, hispanic, pacific islander, white, other };
}
variable Language {
  type discrete [ 3 ] { english, spanish, other };
}
