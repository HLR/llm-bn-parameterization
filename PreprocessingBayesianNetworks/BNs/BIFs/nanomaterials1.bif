network unknown {
}
variable AcuteToxicityByTheExposureRouteOral {
  type discrete [ 6 ] { Less than 5, 5-50, 50-300, 300-2000, 2000-5000, No effect };
}
variable AcuteToxicityDermalExposure {
  type discrete [ 6 ] { Less than 50, 50-200, 200-1000, 1000-2000, 2000-5000, No effect };
}
variable AcuteToxicityExposureByDustInhalation {
  type discrete [ 5 ] { Less than 0.5, 0.5-2, 2-10, 10-20, No effect };
}
variable AcuteToxicityExposureByGasInhalation {
  type discrete [ 5 ] { Less than 100, 100-500, 500-2500, 2500-20000, No effect };
}
variable AcuteToxicityInTheAquaticEnvironment {
  type discrete [ 4 ] { Less than 1, 1-10, 10-100, No effect };
}
variable AdministrativeMeasures {
  type discrete [ 3 ] { High, Medium, Low };
}
variable AerosolFormation {
  type discrete [ 2 ] { With, Without };
}
variable Agglomeration {
  type discrete [ 2 ] { With, Without };
}
variable Amount {
  type discrete [ 3 ] { <10mg, 10-100mg, >100mg };
}
variable BodyProtection {
  type discrete [ 4 ] { No use, Cotton lab coats, Synthetic material lab coats, Chemical protection coveralls };
}
variable ChronicToxicityByTheExposureRouteInhalationDust {
  type discrete [ 5 ] { Less than 0.5, 0.5-2, 2-10, 10-20, No effect };
}
variable ChronicToxicityByTheExposureRouteInhalationGas {
  type discrete [ 3 ] { Less than 50, 50-200, No effect };
}
variable ChronicToxicityDermalExposure {
  type discrete [ 3 ] { Less than 20, 20-200, No effect };
}
variable ChronicToxicityExposureByDustInhalation {
  type discrete [ 3 ] { Less than 0.02, 0.02-0.2, No effect };
}
variable ChronicToxicityExposureOral {
  type discrete [ 3 ] { Less than 10, 10-100, No effect };
}
variable ChronicToxicityInTheAquaticEnvironment {
  type discrete [ 4 ] { Less than 0.01, 0.01-0.1, 0.1-1, No effect };
}
variable ClassificationGHS {
  type discrete [ 5 ] { 1, 2, 3, 4, 5 };
}
variable CrystallineStructure {
  type discrete [ 2 ] { With, Without };
}
variable Duration {
  type discrete [ 3 ] { <30min, 30-240min, >240min };
}
variable DustFormation {
  type discrete [ 2 ] { With, Without };
}
variable Exposure {
  type discrete [ 3 ] { High, Medium, Low };
}
variable EyeIrritation {
  type discrete [ 3 ] { No effect, Reversible irritation, Irreversible damage };
}
variable EyesProtection {
  type discrete [ 4 ] { No use, Safety glasses, Safety goggles, Face shields };
}
variable FootProtection {
  type discrete [ 3 ] { Open shoes, Work shoes, Safety shoes for chemical agents };
}
variable Frequency {
  type discrete [ 5 ] { Daily, Weekly, Monthly, Semiannual, Yearly };
}
variable HandProtection {
  type discrete [ 4 ] { No use, Rubber gloves, Nitrile gloves - 1 pair, Nitrile gloves - 2 pairs };
}
variable Hazard {
  type discrete [ 3 ] { High, Medium, Low };
}
variable MedicalSurveillance {
  type discrete [ 3 ] { No, Yes, Yes_ consider NMs };
}
variable Morphology {
  type discrete [ 3 ] { Spherical, Plates, Rods };
}
variable OccupationalEnvironmentRiskProgram {
  type discrete [ 3 ] { No, Yes, Yes_ consider NMs };
}
variable PeriodicMaintenanceOfCPE {
  type discrete [ 3 ] { No, Yes_ less than 12 months, Yes_ more than 12 months };
}
variable PersonalProtectiveEquipment {
  type discrete [ 3 ] { High, Medium, Low };
}
variable PotentiallyCarcinogenic {
  type discrete [ 3 ] { Confirmed for humans, Possibly toxic to humans, No effect };
}
variable ProtectionByUsingCollectiveProtectiveEquipment {
  type discrete [ 4 ] { Full containment/isolation, Enclosed ventilation, Local ventilation, General mechanical ventilation };
}
variable RespiratoryProtection {
  type discrete [ 3 ] { No use, Safety mask without selection criteria, Respiratory mask according to the respiratory protection program };
}
variable RespiratoryProtectionProgram {
  type discrete [ 3 ] { No, Yes, Yes_ consider NMs };
}
variable RespiratorySensitization {
  type discrete [ 3 ] { There is evidence for humans, There are positive tests for animal testing, No effect };
}
variable Risk {
  type discrete [ 3 ] { High, Medium, Low };
}
variable RiskControl {
  type discrete [ 3 ] { High, Medium, Low };
}
variable RiskTrainingInvolvingNMs {
  type discrete [ 2 ] { No, Yes };
}
variable SizeOfAtLeastOneDimension {
  type discrete [ 2 ] { Less than 100, More than 100 };
}
variable SkinIrritation {
  type discrete [ 4 ] { Skin corrosion, Skin irritation, ILskin irritation, No effect };
}
variable SolubilityInWater {
  type discrete [ 2 ] { Dissolution pH 5 to 9, Insoluble };
}
variable StandardOperatingProcedureOfTask {
  type discrete [ 2 ] { No, Yes };
}
variable SurfaceArea {
  type discrete [ 3 ] { < 10 m2g, 10-49 m2g, >50 m2g };
}
variable SurfaceChargeInSolution {
  type discrete [ 2 ] { Charged, Neutral };
}
variable SurfaceModificationWithHydrophilicGroups {
  type discrete [ 2 ] { Without, With };
}
variable SuspensionStability {
  type discrete [ 2 ] { Less than 30, More than 30 };
}
variable VariablesPhysicoChemical {
  type discrete [ 3 ] { High, Medium, Low };
}
