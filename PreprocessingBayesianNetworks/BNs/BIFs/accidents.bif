network unknown {
}
variable AccidentType {
  type discrete [ 9 ] { Collision, Grounding, Flooding, Fire/Explosion, Capsize, Contact/Crush, Sinking, Overboard, Others };
}
variable EquipmentDevice {
  type discrete [ 2 ] { Devices and equipment on board operate correctly, Devices and equipment not fully utilised or operated correctly };
}
variable ErgonomicDesign {
  type discrete [ 2 ] { Ergonomic friendly, Ergonomic impact of innovative bridge design };
}
variable FairwayTraffic {
  type discrete [ 2 ] { Good, Poor };
}
variable GrossTonnage {
  type discrete [ 4 ] { Less than 300, 300-1000, More than 1000, NA };
}
variable HullType {
  type discrete [ 4 ] { Steel, Wood, Aluminium, Others };
}
variable Information {
  type discrete [ 2 ] { Effective and updated information provided, Insufficient or lack of updated information };
}
variable Length {
  type discrete [ 3 ] { Less than 100, More than 100, NA };
}
variable SeaCondition {
  type discrete [ 2 ] { Good, Poor };
}
variable ShipAge {
  type discrete [ 6 ] { _0_5], [6_10], [11_15], [16-20], More than 20, NA };
}
variable ShipOperation {
  type discrete [ 8 ] { Towing, Loading/Unloading, Pilotage, Manoeuvring, Fishing, At anchor, On passage, Others };
}
variable ShipSpeed {
  type discrete [ 2 ] { Normal, Fast };
}
variable ShipType {
  type discrete [ 10 ] { Passenger vessel, Tug, Barge, Fishing vessel, Container ship, Bulk carrier, RORO, Tanker or chemical ship, Cargo ship, Others };
}
variable TimeOfDay {
  type discrete [ 2 ] { 7am to 7pm, Other };
}
variable VesselCondition {
  type discrete [ 2 ] { Good, Poor };
}
variable VoyageSegment {
  type discrete [ 6 ] { In port, Departure, Arrival, Mid-water, Transit, Others };
}
variable WeatherCondition {
  type discrete [ 2 ] { Good, Poor };
}
