network unknown {
}
variable Distance_Escape_Terrain {
  type discrete [ 4 ] { On Escape Terrain, <=150m away, <=300m away, >300m away };
}
variable Elevation {
  type discrete [ 5 ] { <=500m, <=900m, <=1300m, <=1700m, >1700m };
}
variable Forest_Age_Class {
  type discrete [ 5 ] { Early, Mid, Mature, Old, Non-Forested };
}
variable Location {
  type discrete [ 2 ] { Observations, Random };
}
variable Slope {
  type discrete [ 3 ] { Shallow, Moderate, Steep };
}
variable Snow_Zone {
  type discrete [ 4 ] { Shallow, Moderate, Deep, Very Deep };
}
variable Solar_Insolation {
  type discrete [ 5 ] { Very Low, Low, Moderate, High, Very High };
}
