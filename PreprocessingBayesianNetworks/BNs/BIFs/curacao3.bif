network unknown {
}
variable AccessToPublicTransportation {
  type discrete [ 2 ] { no, yes };
}
variable AirNuisance {
  type discrete [ 2 ] { no, yes };
}
variable CoastalView {
  type discrete [ 2 ] { no, yes };
}
