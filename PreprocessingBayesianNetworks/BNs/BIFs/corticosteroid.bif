network unknown {
}
variable CCRAchieved {
  type discrete [ 2 ] { Achieved, Not Achieved  };
}
variable FinalCSDCAchieved {
  type discrete [ 2 ] { Achieved, Not Achieved  };
}
variable RemissionAchieved {
  type discrete [ 2 ] { Achieved, Not Achieved  };
}
probability ( CCRAchieved | FinalCSDCAchieved ) {
  (Achieved) 0.474, 0.526;
  (Not Achieved ) 0.184, 0.816;
}
probability ( FinalCSDCAchieved ) {
  table 0.522, 0.478;
}
probability ( RemissionAchieved | CCRAchieved, FinalCSDCAchieved ) {
  (Achieved, Achieved) 0.658, 0.342;
  (Not Achieved , Achieved) 0.271, 0.729;
  (Achieved, Not Achieved ) 0.259, 0.741;
  (Not Achieved , Not Achieved ) 0.035, 0.965;
}
