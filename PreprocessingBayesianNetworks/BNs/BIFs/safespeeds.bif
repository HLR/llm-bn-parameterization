}
variable PrecedingRoadwayType {
  type discrete [ 6 ] { Connector Road, Deceleration Lane, Fork, Main Carriageway, Merge, Weaving Section };
}
variable SpeedSign {
  type discrete [ 11 ] { AdvSpeed50, AdvSpeed60, AdvSpeed70, AdvSpeed80, AdvSpeed90, SpeedLimit50, SpeedLimit60, SpeedLimit70, SpeedLimit80, SpeedLimit90, NoSpeedSign };
}
variable WarningSign {
  type discrete [ 2 ] { Present, Not Present };
}
