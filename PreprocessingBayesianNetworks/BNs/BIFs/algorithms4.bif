network unknown {
}
variable X1 {
  type discrete [ 2 ] { a, b };
}
variable X2 {
  type discrete [ 2 ] { c, d };
}
variable X3 {
  type discrete [ 2 ] { e, f };
}
variable X4 {
  type discrete [ 2 ] { g, h };
}
probability ( X1 ) {
  table 0.31, 0.69;
}
probability ( X2 | X1, X4 ) {
  (a, g) 0.38, 0.62;
  (b, g) 0.51, 0.49;
  (a, h) 0.71, 0.29;
  (b, h) 0.14, 0.86;
}
probability ( X3 | X1 ) {
  (a) 0.44, 0.56;
  (b) 0.18, 0.82;
}
probability ( X4 | X3 ) {
  (e) 0.26, 0.74;
  (f) 0.5, 0.5;
}
