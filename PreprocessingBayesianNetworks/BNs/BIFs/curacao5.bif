network unknown {
}
variable AgriculturalDensity {
  type discrete [ 3 ] { low, med, high };
}
variable AllRoadAccess {
  type discrete [ 2 ] { no, yes };
}
variable BuiltUpDensity {
  type discrete [ 3 ] { low, med, high };
}
variable CoUserInteractionConstraints {
  type discrete [ 2 ] { low, high };
}
variable EnvironmentalConstraints {
  type discrete [ 2 ] { yes, no };
}
variable Geology {
  type discrete [ 3 ] { colluvial clay, diabase or other, limestone bare rock };
}
variable GroundwaterDepth {
  type discrete [ 3 ] { less than 25m, between 25 and 60m, over 60m };
}
variable InfrastructureConstraints {
  type discrete [ 2 ] { low, high };
}
variable ProductivityConstraints {
  type discrete [ 2 ] { low, high };
}
variable SiteConstraints {
  type discrete [ 2 ] { low, high };
}
variable Slope {
  type discrete [ 3 ] { flat, moderate, steep };
}
variable SuitabilityStructuralAgriculture {
  type discrete [ 2 ] { no, yes };
}
variable UtilitiesAccess {
  type discrete [ 3 ] { no, planned, yes };
}
probability ( AgriculturalDensity ) {
  table 0.3333333, 0.3333333, 0.3333333;
}
probability ( AllRoadAccess ) {
  table 0.5, 0.5;
}
probability ( BuiltUpDensity ) {
  table 0.3333333, 0.3333333, 0.3333333;
}
probability ( CoUserInteractionConstraints | AgriculturalDensity, BuiltUpDensity ) {
  (low, low) 0.6, 0.4;
  (med, low) 0.8, 0.2;
  (high, low) 1.0, 0.0;
  (low, med) 0.85, 0.15;
  (med, med) 0.8, 0.2;
  (high, med) 1.0, 0.0;
  (low, high) 1.0, 0.0;
  (med, high) 1.0, 0.0;
  (high, high) 1.0, 0.0;
}
probability ( EnvironmentalConstraints ) {
  table 0.5, 0.5;
}
probability ( Geology ) {
  table 0.3333333, 0.3333333, 0.3333333;
}
probability ( GroundwaterDepth ) {
  table 0.3333333, 0.3333333, 0.3333333;
}
probability ( InfrastructureConstraints | AllRoadAccess, UtilitiesAccess ) {
  (no, no) 0.0, 1.0;
  (yes, no) 0.2, 0.8;
  (no, planned) 0.3, 0.7;
  (yes, planned) 0.5, 0.5;
  (no, yes) 0.3, 0.7;
  (yes, yes) 1.0, 0.0;
}
probability ( ProductivityConstraints | Geology, GroundwaterDepth ) {
  (colluvial clay, less than 25m) 1.0, 0.0;
  (diabase or other, less than 25m) 1.0, 0.0;
  (limestone bare rock, less than 25m) 0.9, 0.1;
  (colluvial clay, between 25 and 60m) 0.8, 0.2;
  (diabase or other, between 25 and 60m) 0.8, 0.2;
  (limestone bare rock, between 25 and 60m) 0.7, 0.3;
  (colluvial clay, over 60m) 0.75, 0.25;
  (diabase or other, over 60m) 0.75, 0.25;
  (limestone bare rock, over 60m) 0.65, 0.35;
}
probability ( SiteConstraints | EnvironmentalConstraints, Slope ) {
  (yes, flat) 1.0, 0.0;
  (no, flat) 0.9, 0.1;
  (yes, moderate) 1.0, 0.0;
  (no, moderate) 0.85, 0.15;
  (yes, steep) 0.5, 0.5;
  (no, steep) 0.4, 0.6;
}
probability ( Slope ) {
  table 0.3333333, 0.3333333, 0.3333333;
}
probability ( SuitabilityStructuralAgriculture | CoUserInteractionConstraints, InfrastructureConstraints, ProductivityConstraints, SiteConstraints ) {
  (low, low, low, low) 0.0, 1.0;
  (high, low, low, low) 0.2, 0.8;
  (low, high, low, low) 0.2, 0.8;
  (high, high, low, low) 0.4, 0.6;
  (low, low, high, low) 0.1, 0.9;
  (high, low, high, low) 0.3, 0.7;
  (low, high, high, low) 0.3, 0.7;
  (high, high, high, low) 0.0, 1.0;
  (low, low, low, high) 0.4, 0.6;
  (high, low, low, high) 0.6, 0.4;
  (low, high, low, high) 0.6, 0.4;
  (high, high, low, high) 0.65, 0.35;
  (low, low, high, high) 0.5, 0.5;
  (high, low, high, high) 0.2, 0.8;
  (low, high, high, high) 0.75, 0.25;
  (high, high, high, high) 0.4, 0.6;
}
probability ( UtilitiesAccess ) {
  table 0.3333333, 0.3333333, 0.3333333;
}
