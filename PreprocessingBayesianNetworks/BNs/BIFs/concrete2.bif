network unknown {
}
variable Basement {
  type discrete [ 2 ] { False, True };
}
variable BlueConcrete {
  type discrete [ 2 ] { False, True };
}
variable BuildingClass {
  type discrete [ 4 ] { Single Family House, MultiFamily House, School Building, Other Building };
}
variable ConstructionYear {
  type discrete [ 5 ] { 1930-1955, 1955-1960, 1960-1968, 1968-1975, 1975-1980 };
}
probability ( Basement | ConstructionYear ) {
  (1930-1955) 0.15, 0.85;
  (1955-1960) 0.36, 0.64;
  (1960-1968) 0.23, 0.77;
  (1968-1975) 0.4, 0.6;
  (1975-1980) 0.72, 0.28;
}
probability ( BlueConcrete | ConstructionYear ) {
  (1930-1955) 0.77, 0.23;
  (1955-1960) 0.6, 0.4;
  (1960-1968) 0.4, 0.6;
  (1968-1975) 0.7, 0.3;
  (1975-1980) 0.88, 0.12;
}
probability ( BuildingClass | Basement, BlueConcrete ) {
  (False, False) 0.47, 0.05, 0.27, 0.21;
  (True, False) 0.43, 0.37, 0.09, 0.11;
  (False, True) 0.07, 0.58, 0.16, 0.19;
  (True, True) 0.14, 0.53, 0.06, 0.27;
}
probability ( ConstructionYear ) {
  table 0.21, 0.19, 0.27, 0.18, 0.15;
}
