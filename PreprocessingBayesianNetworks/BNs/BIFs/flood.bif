network unknown {
}
variable Bulk_Density {
  type discrete [ 6 ] { 0 to 0.25, 0.25 to 0.5, 0.5 to 0.75, 0.75 to 1, 1 to 1.25, 1.25 to 1.5 };
}
variable Daily_Runoff {
  type discrete [ 4 ] { 0 to 18, 18 to 36, 36 to 54, 54 to 72 };
}
variable Erosion {
  type discrete [ 2 ] { High, Low };
}
variable Farm_Yield {
  type discrete [ 2 ] { Positive, Negative };
}
variable Flood_Alleviation {
  type discrete [ 2 ] { Positive, Negative };
}
variable Land_Use {
  type discrete [ 4 ] { Arable, Arable With Grass, Grassland, Woodland };
}
variable Nutrients {
  type discrete [ 2 ] { High, Low };
}
variable Product_Weight {
  type discrete [ 4 ] { 0 to 2550, 2550 to 5100, 5100 to 7650, 7650 to 10200 };
}
variable Rainfall {
  type discrete [ 7 ] { 0 to 0.4, 0.4 to 0.8, 0.8 to 1.2, 1.2 to 1.6, 1.6 to 2, 2 to 2.4, 2.4 to 2.8 };
}
variable Runoff {
  type discrete [ 2 ] { 0 to 7.7, 7.7 to 15.4 };
}
variable Senesced {
  type discrete [ 4 ] { 0 to 77.5, 77.5 to 155, 155 to 232.5, 232.5 to 310 };
}
variable Slope {
  type discrete [ 2 ] { Flat, Sloped };
}
variable SOMC {
  type discrete [ 5 ] { 0 to 1.833e5, 1.833e5 to 3.666e5, 3.666e5 to 5.499e5, 5.499e5 to 7.322e5, 7.322e5 to 9.165e5 };
}
variable Temperature {
  type discrete [ 5 ] { 7.5 to 8.54, 8.54 to 9.06, 9.06 to 9.58, 9.58 to 10.1, 10.1 to 10.62 };
}
variable Texture {
  type discrete [ 2 ] { Loamy, Clay };
}
variable Tillage {
  type discrete [ 2 ] { Conservational, Conventional };
}
variable VESS {
  type discrete [ 5 ] { Fragile, Intact, Firm, Compact, Very Compact };
}
variable Water {
  type discrete [ 4 ] { 0 to 159, 159 to 318, 318 to 477, 477 to 636 };
}
variable Water_Stress {
  type discrete [ 4 ] { 0 to 3.66, 3.66 to 7.32, 7.32 to 10.98, 10.98 to 14.64 };
}
variable Weeds {
  type discrete [ 2 ] { Present, Absent };
}
variable Weight {
  type discrete [ 5 ] { 0 to 5000, 5000 to 10000, 10000 to 15000, 15000 to 20000, 20000 to 25000 };
}
variable Yield {
  type discrete [ 2 ] { Decrease, Increase };
}
