network unknown {
}
variable BGFibers {
  type discrete [ 2 ] { false, true };
}
variable BGU {
  type discrete [ 2 ] { false, true };
}
variable CaseFind {
  type discrete [ 2 ] { false, true };
}
variable DNAfind {
  type discrete [ 4 ] { DNA X, DNA U, DNA X + U, No DNA };
}
variable DNAU {
  type discrete [ 2 ] { false, true };
}
variable DNAX {
  type discrete [ 2 ] { false, true };
}
variable FiberFind {
  type discrete [ 2 ] { false, true };
}
variable FibersSweater {
  type discrete [ 2 ] { false, true };
}
variable ItemProposition {
  type discrete [ 2 ] { false, true };
}
variable Prop {
  type discrete [ 2 ] { H1, H2 };
}
variable TPRaltactX {
  type discrete [ 2 ] { false, true };
}
variable TPRUstrangledY {
  type discrete [ 2 ] { false, true };
}
variable TPRXstrangledY {
  type discrete [ 2 ] { false, true };
}
variable TPRYtoSweater {
  type discrete [ 2 ] { false, true };
}
variable UstrangledY {
  type discrete [ 2 ] { false, true };
}
variable Xaltact {
  type discrete [ 2 ] { false, true };
}
variable XstrangledY {
  type discrete [ 2 ] { false, true };
}
probability ( BGFibers ) {
  table 0.8, 0.2;
}
probability ( BGU ) {
  table 0.4, 0.6;
}
probability ( CaseFind | DNAfind, FiberFind ) {
  (DNA X, false) 0.0, 1.0;
  (DNA U, false) 0.0, 1.0;
  (DNA X + U, false) 0.0, 1.0;
  (No DNA, false) 0.0, 1.0;
  (DNA X, true) 1.0, 0.0;
  (DNA U, true) 0.0, 1.0;
  (DNA X + U, true) 0.0, 1.0;
  (No DNA, true) 0.0, 1.0;
}
probability ( DNAfind | DNAU, DNAX ) {
  (false, false) 0.0, 0.0, 0.0, 1.0;
  (true, false) 0.0, 1.0, 0.0, 0.0;
  (false, true) 1.0, 0.0, 0.0, 0.0;
  (true, true) 0.0, 0.0, 1.0, 0.0;
}
probability ( DNAU | BGU, TPRUstrangledY ) {
  (false, false) 1.0, 0.0;
  (true, false) 0.0, 1.0;
  (false, true) 0.0, 1.0;
  (true, true) 0.0, 1.0;
}
probability ( DNAX | TPRaltactX, TPRXstrangledY ) {
  (false, false) 1.0, 0.0;
  (true, false) 0.0, 1.0;
  (false, true) 0.0, 1.0;
  (true, true) 0.0, 1.0;
}
probability ( FiberFind | FibersSweater ) {
  (false) 1.0, 0.0;
  (true) 0.0, 1.0;
}
probability ( FibersSweater | BGFibers, TPRYtoSweater ) {
  (false, false) 1.0, 0.0;
  (true, false) 0.0, 1.0;
  (false, true) 0.0, 1.0;
  (true, true) 0.0, 1.0;
}
probability ( ItemProposition ) {
  table 0.5, 0.5;
}
probability ( Prop ) {
  table 0.5, 0.5;
}
probability ( TPRaltactX | Xaltact ) {
  (false) 1.0, 0.0;
  (true) 0.4, 0.6;
}
probability ( TPRUstrangledY | ItemProposition, UstrangledY ) {
  (false, false) 1.0, 0.0;
  (true, false) 1.0, 0.0;
  (false, true) 1.0, 0.0;
  (true, true) 0.05, 0.95;
}
probability ( TPRXstrangledY | ItemProposition, XstrangledY ) {
  (false, false) 1.0, 0.0;
  (true, false) 1.0, 0.0;
  (false, true) 1.0, 0.0;
  (true, true) 0.05, 0.95;
}
probability ( TPRYtoSweater | ItemProposition ) {
  (false) 1.0, 0.0;
  (true) 0.4, 0.6;
}
probability ( UstrangledY | Prop ) {
  (H1) 1.0, 0.0;
  (H2) 0.0, 1.0;
}
probability ( Xaltact ) {
  table 0.0, 1.0;
}
probability ( XstrangledY | Prop ) {
  (H1) 0.0, 1.0;
  (H2) 1.0, 0.0;
}
